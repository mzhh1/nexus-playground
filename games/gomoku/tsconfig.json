{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": [
            "ES2022",
            "DOM",
            "DOM.Iterable"
        ],
        "jsx": "react-jsx",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "declaration": true,
        "declarationDir": "dist",
        "outDir": "dist",
        "rootDir": ".",
        "baseUrl": ".",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true
    },
    "include": [
        "logic/**/*",
        "ui/**/*",
        "*.d.ts",
        "*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}