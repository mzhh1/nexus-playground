{
    "name": "@nexus/game-gomoku",
    "version": "1.0.0",
    "type": "module",
    "main": "./dist/logic.mjs",
    "scripts": {
        "build": "npm run build:logic && npm run build:ui",
        "build:logic": "tsup",
        "build:ui": "vite build -c vite.config.ui.ts",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@nexus/game-sdk": "workspace:*"
    },
    "devDependencies": {
        "tsup": "^8.0.1",
        "typescript": "^5.3.3",
        "vite": "^5.0.12"
    }
}