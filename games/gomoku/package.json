{
    "name": "@nexus/game-gomoku",
    "version": "1.0.0",
    "description": "Gomoku (Five in a Row) game for Nexus Playground",
    "type": "module",
    "main": "dist/logic/index.js",
    "module": "dist/logic/index.js",
    "exports": {
        ".": {
            "import": "./dist/logic/index.js",
            "types": "./dist/logic/index.d.ts"
        },
        "./ui": {
            "import": "./dist/ui/index.js",
            "types": "./dist/ui/index.d.ts"
        }
    },
    "scripts": {
        "dev": "vite build --watch",
        "build": "vite build",
        "build:logic": "tsup logic/index.ts --format esm --dts --out-dir dist/logic",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@nexus/game-sdk": "file:../../packages/game-sdk"
    },
    "peerDependencies": {
        "react": "^18.0.0",
        "react-dom": "^18.0.0"
    },
    "devDependencies": {
        "@originjs/vite-plugin-federation": "^1.3.5",
        "@types/react": "^18.2.55",
        "@types/react-dom": "^18.2.19",
        "@vitejs/plugin-react": "^4.2.1",
        "tsup": "^8.0.0",
        "typescript": "^5.3.3",
        "vite": "^5.1.0"
    },
    "files": [
        "dist",
        "logic",
        "ui"
    ]
}