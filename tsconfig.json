{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@nexus/shared-types": ["./core-framework/packages/shared-types/src"],
      "@nexus/game-sdk": ["./core-framework/packages/game-sdk/src"],
      "@nexus/platform-core": ["./core-framework/packages/platform-core/src"],
      "@nexus/platform-core/llm-adapter": ["./core-framework/packages/platform-core/src/llm-adapter"],
      "@nexus/web-client": ["./core-framework/packages/web-client/src"]
    }
  },
  "exclude": ["node_modules", "dist", "build", ".next"]
}

