{
    "name": "@nexusgame/cli",
    "version": "0.1.2",
    "type": "module",
    "description": "Nexus Game Engine - Local development CLI tool",
    "bin": {
        "nexus-dev": "./dist/index.js"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup src/index.ts --format esm --no-splitting && cp ../../nexus-engine/dist/engine-worker.js dist/engine-worker.js",
        "dev": "tsx src/index.ts"
    },
    "dependencies": {
        "miniflare": "^4.20260302.0",
        "commander": "^12.0.0",
        "chalk": "^5.3.0"
    },
    "devDependencies": {
        "tsup": "^8.0.1",
        "tsx": "^4.7.0",
        "typescript": "^5.3.3",
        "@types/node": "^20.11.0"
    },
    "publishConfig": {
        "access": "public"
    }
}