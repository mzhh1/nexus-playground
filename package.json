{
    "name": "nexus-playground",
    "private": true,
    "license": "MIT",
    "scripts": {
        "build": "turbo run build",
        "dev": "turbo run dev",
        "dev:workers": "pnpm --parallel --filter ./hono_backend --filter ./nexus-engine run dev",
        "deploy:workers": "pnpm --filter ./hono_backend run deploy && pnpm --filter ./nexus-engine run deploy",
        "typecheck:workers": "pnpm --filter ./hono_backend run typecheck && pnpm --filter ./nexus-engine run build",
        "lint": "turbo run lint",
        "clean": "turbo run clean",
        "format": "prettier --write \"**/*.{ts,tsx,md}\""
    },
    "devDependencies": {
        "turbo": "^1.11.3",
        "prettier": "^3.2.4",
        "typescript": "^5.3.3",
        "eslint": "^8.56.0"
    },
    "packageManager": "pnpm@8.15.1",
    "engines": {
        "node": ">=18"
    }
}