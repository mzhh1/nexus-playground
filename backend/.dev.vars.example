# 复制为 .dev.vars 用于本地 wrangler dev。不要提交 .dev.vars。

# Logto 配置（本地可覆盖 wrangler.toml 的值）
# ISSUER_ENDPOINT=https://nexus-playground.apiservice.autolab-server.site
# WORKER_RESOURCE_INDICATOR=https://nexus-playground.apiservice.autolab-server.site
DEBUG=true

# Nexus Engine
NEXUS_ENGINE_URL=
NEXUS_ENGINE_ADMIN_SECRET=
NEXUS_ENGINE_JWT_SECRET=

# LLM Webhook
LLM_WEBHOOK_SECRET=
OPENAI_API_BASE=
OPENAI_API_KEY=

# Game Workers（逗号分隔）
WORKER_URL="https://uno.npgames.autolab-server.site/"

# CORS（逗号分隔）
CORS_ALLOW_ORIGINS=http://localhost:3004
