{
  "extends": "../../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": false,
    "declaration": true,
    "declarationMap": true,
    "incremental": false,
    "paths": {
      "@nexus/shared-types": ["../shared-types/dist/index.d.ts"],
      "@nexus/game-sdk": ["../game-sdk/dist/index.d.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"],
  "references": [
    {
      "path": "../shared-types"
    },
    {
      "path": "../game-sdk"
    }
  ]
}

